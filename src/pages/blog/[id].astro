---
import BaseLayout from '../../layouts/BaseLayout.astro'
import StructuredData from '../../components/StructuredData.astro'
import { getCollection, render } from 'astro:content'

export async function getStaticPaths() {
	const posts = await getCollection('blog')
	return posts.map((post) => ({
		params: { id: post.id },
		props: { post },
	}))
}

const { post } = Astro.props
const { Content } = await render(post)

function readingTime(body: string): string {
	const words = body.split(/\s+/).length
	const minutes = Math.ceil(words / 250)
	return `${minutes} min read`
}

function formatDate(date: Date): string {
	return date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })
}
---

<BaseLayout
	title={`${post.data.title} | Start & Scale Blog`}
	description={post.data.description}
	canonical={`/blog/${post.id}`}
	ogType="article"
>
	<StructuredData
		type="blog"
		blogTitle={post.data.title}
		blogDescription={post.data.description}
		blogPublished={post.data.date.toISOString()}
		blogAuthor={post.data.author}
	/>

		<main>
			<!-- Post Header -->
			<section class="bg-dark pt-32 pb-16 sm:pt-40 sm:pb-20 lg:pt-48 lg:pb-28">
				<div class="max-w-6xl mx-auto px-5 sm:px-8">
					<a href="/blog" class="text-accent-muted text-btn hover:text-white transition-colors duration-150 cursor-pointer inline-block mb-8">&larr; All posts</a>
					<h1 class="font-display text-white text-h1 lg:text-[3.75rem] lg:leading-[1.05] max-w-4xl">
						{post.data.title}
					</h1>
					<p class="text-body-lg text-body-light mt-6">
						{formatDate(post.data.date)} &middot; {readingTime(post.body ?? '')} &middot; {post.data.author}
					</p>
				</div>
			</section>

			<!-- Post Content -->
			<section class="bg-background py-12 sm:py-16 lg:py-20">
				<div class="max-w-6xl mx-auto px-5 sm:px-8">
					<article class="prose max-w-3xl">
						<Content />
					</article>
				</div>
			</section>

			<!-- CTA Block -->
			<section class="bg-dark py-16 sm:py-20 lg:py-24">
				<div class="max-w-6xl mx-auto px-5 sm:px-8 text-center">
					<h2 class="font-display text-white text-h2 lg:text-[3rem] lg:leading-[1.1]">Want to talk through any of this?</h2>
					<p class="text-body-lg text-body-light mt-4 max-w-xl mx-auto">30 minutes. No pitch. Just a conversation about where you are and what might help.</p>
					<div class="mt-10 flex flex-wrap justify-center gap-4 items-center">
						<a href="https://calendly.com/chris-ssgrowthadvisors/" target="_blank" rel="noopener noreferrer" class="bg-accent text-white text-btn px-7 py-3.5 rounded hover:bg-accent-hover transition-colors duration-150 cursor-pointer inline-block">
							Book a Call
						</a>
						<a href="/contact" class="text-body-light text-btn hover:text-white transition-colors duration-150 cursor-pointer inline-block py-3.5">
							Or send a message &rarr;
						</a>
					</div>
				</div>
			</section>
</BaseLayout>

<style is:global>
	.prose h2 {
		font-family: var(--font-display);
		color: var(--color-headline);
		font-size: 1.5rem;
		line-height: 1.2;
		font-weight: 600;
		letter-spacing: -0.01em;
		margin-top: 2.5rem;
		margin-bottom: 1rem;
	}
	.prose p {
		color: var(--color-body);
		font-size: 1.0625rem;
		line-height: 1.7;
		margin-bottom: 1.25rem;
	}
	.prose strong {
		color: var(--color-headline);
		font-weight: 600;
	}
	.prose ol {
		list-style-type: decimal;
		padding-left: 1.5rem;
		margin-bottom: 1.25rem;
	}
	.prose ol li {
		color: var(--color-body);
		font-size: 1.0625rem;
		line-height: 1.7;
		margin-bottom: 0.75rem;
		padding-left: 0.25rem;
	}
	.prose ul {
		list-style-type: disc;
		padding-left: 1.5rem;
		margin-bottom: 1.25rem;
	}
	.prose ul li {
		color: var(--color-body);
		font-size: 1.0625rem;
		line-height: 1.7;
		margin-bottom: 0.5rem;
	}
</style>
