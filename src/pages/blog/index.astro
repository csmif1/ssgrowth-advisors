---
import BaseLayout from '../../layouts/BaseLayout.astro'
import StructuredData from '../../components/StructuredData.astro'
import { getCollection } from 'astro:content'

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.date.valueOf() - a.data.date.valueOf()
)

function readingTime(body: string): string {
	const words = body.split(/\s+/).length
	const minutes = Math.ceil(words / 250)
	return `${minutes} min read`
}

function formatDate(date: Date): string {
	return date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })
}
---

<BaseLayout
	title="Blog | Start & Scale Growth Advisory"
	description="Practical writing on revenue, operations, and growth for founders and operators. No theory. No fluff."
	canonical="/blog"
>
	<StructuredData type="organization" />
					<a href="/case-studies" class="text-nav text-body-light hover:text-accent-muted transition-colors duration-150 cursor-pointer">Case Studies</a>
					<a href="/blog" class="text-nav text-accent-muted transition-colors duration-150 cursor-pointer">Blog</a>
					<a href="/resources" class="text-nav text-body-light hover:text-accent-muted transition-colors duration-150 cursor-pointer">Resources</a>
					<a href="/contact" class="text-nav text-body-light hover:text-accent-muted transition-colors duration-150 cursor-pointer">Contact</a>
				</div>
				<a href="/contact" class="bg-accent text-white text-btn px-5 py-2.5 rounded hover:bg-accent-hover transition-colors duration-150 cursor-pointer">Book a Call</a>
			</div>
		</nav>

		<main>
			<!-- Hero -->
			<section class="bg-dark pt-32 pb-16 sm:pt-40 sm:pb-20 lg:pt-48 lg:pb-28">
				<div class="max-w-6xl mx-auto px-5 sm:px-8">
					<h1 class="font-display text-white text-h1 lg:text-[3.75rem] lg:leading-[1.05] max-w-4xl">
						Writing.
					</h1>
					<p class="text-body-lg text-body-light mt-6 max-w-2xl">
						Practical thinking on revenue, operations, and growth. From inside the companies, not from the outside looking in.
					</p>
				</div>
			</section>

			<!-- Blog Listing -->
			<section class="bg-background py-12 sm:py-16 lg:py-20">
				<div class="max-w-6xl mx-auto px-5 sm:px-8">
					<div class="space-y-8">
						{posts.map((post) => (
							<article class="border-b border-border pb-8 last:border-b-0 last:pb-0">
								<a href={`/blog/${post.id}`} class="group cursor-pointer block">
									<p class="text-small text-body">{formatDate(post.data.date)} &middot; {readingTime(post.body ?? '')} &middot; {post.data.author}</p>
									<h2 class="font-display text-headline text-h2 lg:text-[2.25rem] lg:leading-[1.1] mt-3 group-hover:text-accent transition-colors duration-150">{post.data.title}</h2>
									<p class="text-body-lg text-body mt-3 max-w-3xl">{post.data.description}</p>
									<span class="text-accent text-btn mt-4 inline-block group-hover:text-accent-hover transition-colors duration-150">Read post &rarr;</span>
								</a>
							</article>
						))}
					</div>
				</div>
			</section>

			<!-- CTA Block -->
			<section class="bg-dark py-16 sm:py-20 lg:py-24">
				<div class="max-w-6xl mx-auto px-5 sm:px-8 text-center">
					<h2 class="font-display text-white text-h2 lg:text-[3rem] lg:leading-[1.1]">Want to talk through any of this?</h2>
					<p class="text-body-lg text-body-light mt-4 max-w-xl mx-auto">30 minutes. I'll listen to where you are and tell you what I'd do differently.</p>
					<div class="mt-10 flex flex-wrap justify-center gap-4 items-center">
						<a href="/contact" class="bg-accent text-white text-btn px-7 py-3.5 rounded hover:bg-accent-hover transition-colors duration-150 cursor-pointer inline-block">
							Book a Call
						</a>
						<a href="/contact" class="text-body-light text-btn hover:text-white transition-colors duration-150 cursor-pointer inline-block py-3.5">
							Or send a message &rarr;
						</a>
					</div>
				</div>
			</section>
</BaseLayout>
