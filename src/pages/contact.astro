---
import BaseLayout from '../layouts/BaseLayout.astro'
import StructuredData from '../components/StructuredData.astro'
---

<BaseLayout
	title="Contact | Start & Scale Growth Advisory"
	description="Book a 30-minute call or send a message. No pitch, no pressure. Growth advisory for founders and operators."
	canonical="/contact"
>
	<StructuredData type="organization" />
			<!-- Hero -->
			<section class="bg-dark pt-32 pb-16 sm:pt-40 sm:pb-20 lg:pt-48 lg:pb-28">
				<div class="max-w-6xl mx-auto px-5 sm:px-8">
					<h1 class="font-display text-white text-h1 lg:text-[3.75rem] lg:leading-[1.05] max-w-4xl">
						Let's talk.
					</h1>
					<p class="text-body-lg text-body-light mt-6 max-w-2xl">
						Pick a time on the calendar, or send us a message. Either way, we'll get back to you within 24 hours.
					</p>
				</div>
			</section>

			<!-- Two-Column: Calendly + Form -->
			<section class="bg-background py-12 sm:py-16 lg:py-20">
				<div class="max-w-6xl mx-auto px-5 sm:px-8">
					<div class="grid grid-cols-1 lg:grid-cols-2 gap-8 sm:gap-10 lg:gap-16">

						<!-- Schedule a Call -->
						<div>
							<h2 class="font-display text-headline text-h2 lg:text-[2.25rem] lg:leading-[1.1]">Schedule a call</h2>
							<p class="text-body text-body mt-4">30 minutes. No pitch, no prep needed. Just a conversation about where you are.</p>

							<!-- Calendly Inline Embed -->
							<div class="mt-6 sm:mt-8 rounded overflow-hidden calendly-container">
								<div class="calendly-inline-widget" data-url="https://calendly.com/chris-ssgrowthadvisors/?hide_gdpr_banner=1" style="min-width:280px;width:100%;height:100%;"></div>
							</div>
						</div>

						<!-- Send Us a Message -->
						<div>
							<h2 class="font-display text-headline text-h2 lg:text-[2.25rem] lg:leading-[1.1]">Send us a message</h2>
							<p class="text-body text-body mt-4">We respond to every message within one business day.</p>

							<form class="mt-6 sm:mt-8 space-y-5 sm:space-y-6" action="#" method="POST">
								<div>
									<label for="name" class="text-small text-headline font-semibold block mb-2">Name <span class="text-accent">*</span></label>
									<input
										type="text"
										id="name"
										name="name"
										required
										class="w-full bg-surface border border-border rounded px-4 py-3 text-body text-headline placeholder:text-body focus:outline-none focus:border-accent focus:ring-1 focus:ring-accent transition-colors duration-150"
										placeholder="Your name"
									/>
								</div>

								<div>
									<label for="email" class="text-small text-headline font-semibold block mb-2">Email <span class="text-accent">*</span></label>
									<input
										type="email"
										id="email"
										name="email"
										required
										class="w-full bg-surface border border-border rounded px-4 py-3 text-body text-headline placeholder:text-body focus:outline-none focus:border-accent focus:ring-1 focus:ring-accent transition-colors duration-150"
										placeholder="you@company.com"
									/>
								</div>

								<div>
									<label for="company" class="text-small text-headline font-semibold block mb-2">Company</label>
									<input
										type="text"
										id="company"
										name="company"
										class="w-full bg-surface border border-border rounded px-4 py-3 text-body text-headline placeholder:text-body focus:outline-none focus:border-accent focus:ring-1 focus:ring-accent transition-colors duration-150"
										placeholder="Your company"
									/>
								</div>

								<div>
									<label for="message" class="text-small text-headline font-semibold block mb-2">Message</label>
									<textarea
										id="message"
										name="message"
										rows="5"
										class="w-full bg-surface border border-border rounded px-4 py-3 text-body text-headline placeholder:text-body focus:outline-none focus:border-accent focus:ring-1 focus:ring-accent transition-colors duration-150 resize-y"
										placeholder="What's on your mind?"
									></textarea>
								</div>

								<button
									type="submit"
									class="bg-accent text-white text-btn px-7 py-3.5 rounded hover:bg-accent-hover transition-colors duration-150 cursor-pointer inline-block"
								>
									Send Message
								</button>
							</form>
						</div>
					</div>

					<!-- Location -->
					<div class="mt-10 sm:mt-16 pt-8 border-t border-border">
						<p class="text-small text-body">Marblehead, MA &middot; Working with founders and operators everywhere.</p>
					</div>
				</div>
			</section>

	<!-- Calendly embed script -->
	<link href="https://assets.calendly.com/assets/external/widget.css" rel="stylesheet" />
	<script type="text/javascript" src="https://assets.calendly.com/assets/external/widget.js" async></script>

	<style>
		.calendly-container {
			height: 380px;
		}
		@media (min-width: 640px) {
			.calendly-container {
				height: 500px;
			}
		}
		@media (min-width: 1024px) {
			.calendly-container {
				height: 700px;
			}
		}
	</style>
</BaseLayout>
