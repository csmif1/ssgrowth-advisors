---
import BaseLayout from '../layouts/BaseLayout.astro'
import StructuredData from '../components/StructuredData.astro'
---

<BaseLayout
	title="Start & Scale | Growth Advisory for Founders & Operators"
	description="Revenue strategy, operations, and AI advisory for founder-led startups and SMBs scaling past the ceiling. 15+ years inside WeWork, CloudKitchens, and Apple."
>
	<StructuredData type="organization" />

	<!-- Hero -->
	<section class="bg-dark pt-32 pb-16 sm:pt-40 sm:pb-20 lg:pt-48 lg:pb-28">
		<div class="max-w-6xl mx-auto px-5 sm:px-8">
			<h1 class="font-display text-white text-h1 lg:text-[3.75rem] lg:leading-[1.05] max-w-4xl">
				Your company outgrew your playbook.
			</h1>
			<p class="text-body-lg text-body-light mt-6 max-w-2xl">
				We help founders and operators build the revenue engine, team structure, and systems to scale past the ceiling — from inside, not from a slide deck.
			</p>
			<div class="mt-10 flex flex-wrap gap-4 items-center">
				<a href="https://calendly.com/chris-ssgrowthadvisors/" target="_blank" rel="noopener noreferrer" class="bg-accent text-white text-btn px-7 py-3.5 rounded hover:bg-accent-hover transition-colors duration-150 cursor-pointer inline-block">
					Book a Call
				</a>
				<a href="/case-studies" class="text-accent-muted text-btn hover:text-white transition-colors duration-150 cursor-pointer inline-block py-3.5">
					See the Work &rarr;
				</a>
			</div>
		</div>
	</section>

	<!-- Proof Strip -->
	<section class="bg-dark-surface py-12 sm:py-16 lg:py-20">
		<div class="max-w-6xl mx-auto px-5 sm:px-8">
			<div class="grid grid-cols-2 lg:grid-cols-4 gap-8 lg:gap-12">
				<div>
					<p class="font-display text-accent text-stat lg:text-[4.5rem] lg:leading-none">$120M</p>
					<p class="text-small text-body-light mt-2">ARR scaled in 24 months</p>
				</div>
				<div>
					<p class="font-display text-accent text-stat lg:text-[4.5rem] lg:leading-none">9</p>
					<p class="text-small text-body-light mt-2">Markets launched from zero</p>
				</div>
				<div>
					<p class="font-display text-accent text-stat lg:text-[4.5rem] lg:leading-none">42</p>
					<p class="text-small text-body-light mt-2">Person org built in 8 months</p>
				</div>
				<div>
					<p class="font-display text-accent text-stat lg:text-[4.5rem] lg:leading-none">15+</p>
					<p class="text-small text-body-light mt-2">Years in founder-led companies</p>
				</div>
			</div>
		</div>
	</section>

	<!-- Experience Strip -->
	<section class="bg-background py-12 sm:py-16">
		<div class="max-w-6xl mx-auto px-5 sm:px-8 text-center">
			<p class="text-small text-body uppercase tracking-widest mb-6">Built and scaled at</p>
			<div class="flex flex-wrap justify-center items-center gap-x-10 gap-y-4">
				<span class="font-display text-headline text-xl sm:text-2xl font-semibold">WeWork</span>
				<span class="text-border hidden sm:inline" aria-hidden="true">&mdash;</span>
				<span class="font-display text-headline text-xl sm:text-2xl font-semibold">CloudKitchens</span>
				<span class="text-border hidden sm:inline" aria-hidden="true">&mdash;</span>
				<span class="font-display text-headline text-xl sm:text-2xl font-semibold">Apple</span>
				<span class="text-border hidden sm:inline" aria-hidden="true">&mdash;</span>
				<span class="font-display text-headline text-xl sm:text-2xl font-semibold">Allwhere</span>
			</div>
		</div>
	</section>

	<!-- Services Overview -->
	<section class="bg-surface py-12 sm:py-16 lg:py-20">
		<div class="max-w-6xl mx-auto px-5 sm:px-8">
			<h2 class="font-display text-headline text-h2 lg:text-[3rem] lg:leading-[1.1]">What we do</h2>
			<p class="text-body-lg text-body mt-4 max-w-2xl">Four practice areas. One operating principle: clarity drives growth.</p>

			<div class="grid grid-cols-1 sm:grid-cols-2 gap-6 mt-10">
				<!-- Revenue & GTM -->
				<article class="bg-background p-6 lg:p-8 rounded hover:shadow-md transition-shadow duration-200 cursor-pointer group">
					<h3 class="font-display text-headline text-h3">Revenue & GTM</h3>
					<p class="text-body text-body mt-3">Sales process, pipeline architecture, pricing, and channel strategy. From first rep to full revenue org.</p>
					<a href="/services" class="text-accent text-btn mt-4 inline-block group-hover:text-accent-hover transition-colors duration-150">
						Learn how &rarr;
					</a>
				</article>

				<!-- Operations & Systems -->
				<article class="bg-background p-6 lg:p-8 rounded hover:shadow-md transition-shadow duration-200 cursor-pointer group">
					<h3 class="font-display text-headline text-h3">Operations & Systems</h3>
					<p class="text-body text-body mt-3">CRM, marketing automation, process design, and team structure. We configure and deploy the systems ourselves.</p>
					<a href="/services" class="text-accent text-btn mt-4 inline-block group-hover:text-accent-hover transition-colors duration-150">
						Learn how &rarr;
					</a>
				</article>

				<!-- Fundraising & Investor Readiness -->
				<article class="bg-background p-6 lg:p-8 rounded hover:shadow-md transition-shadow duration-200 cursor-pointer group">
					<h3 class="font-display text-headline text-h3">Fundraising & Investor Readiness</h3>
					<p class="text-body text-body mt-3">Deck, narrative, metrics packaging, and investor outreach strategy. Shaped by experience from stealth to IPO-track.</p>
					<a href="/services" class="text-accent text-btn mt-4 inline-block group-hover:text-accent-hover transition-colors duration-150">
						Learn how &rarr;
					</a>
				</article>

				<!-- AI & Automation Advisory -->
				<article class="bg-background p-6 lg:p-8 rounded hover:shadow-md transition-shadow duration-200 cursor-pointer group">
					<h3 class="font-display text-headline text-h3">AI & Automation Advisory</h3>
					<p class="text-body text-body mt-3">Feasibility analysis, tool selection, and implementation. We build production AI systems, not strategy decks.</p>
					<a href="/services" class="text-accent text-btn mt-4 inline-block group-hover:text-accent-hover transition-colors duration-150">
						Learn how &rarr;
					</a>
				</article>
			</div>
		</div>
	</section>

	<!-- Case Study Teaser -->
	<section class="bg-background py-12 sm:py-16 lg:py-20">
		<div class="max-w-6xl mx-auto px-5 sm:px-8">
			<h2 class="font-display text-headline text-h2 lg:text-[3rem] lg:leading-[1.1]">Selected work</h2>
			<p class="text-body-lg text-body mt-4 max-w-2xl">Outcomes from founder-led companies navigating inflection points.</p>

			<div class="grid grid-cols-1 sm:grid-cols-3 gap-6 mt-10">
				<article class="bg-surface p-6 lg:p-8 rounded">
					<p class="font-display text-accent text-stat">210%</p>
					<p class="text-small text-body uppercase tracking-wider mt-1 mb-4">of plan</p>
					<h3 class="font-display text-headline text-h4">National Nonprofit</h3>
					<p class="text-body text-body mt-2">Fundraising infrastructure and technology modernization for a 15-year-old organization across 29 states.</p>
					<a href="/case-studies" class="text-accent text-btn mt-4 inline-block hover:text-accent-hover transition-colors duration-150 cursor-pointer">
						Read more &rarr;
					</a>
				</article>

				<article class="bg-surface p-6 lg:p-8 rounded">
					<p class="font-display text-accent text-stat">0→1</p>
					<p class="text-small text-body uppercase tracking-wider mt-1 mb-4">GTM build</p>
					<h3 class="font-display text-headline text-h4">Off-Grid Education Startup</h3>
					<p class="text-body text-body mt-2">Complete go-to-market strategy, brand positioning, and marketing infrastructure for a new entrant in a niche market.</p>
					<a href="/case-studies" class="text-accent text-btn mt-4 inline-block hover:text-accent-hover transition-colors duration-150 cursor-pointer">
						Read more &rarr;
					</a>
				</article>

				<article class="bg-surface p-6 lg:p-8 rounded">
					<p class="font-display text-accent text-stat">19</p>
					<p class="text-small text-body uppercase tracking-wider mt-1 mb-4">Edge Functions shipped</p>
					<h3 class="font-display text-headline text-h4">Legal-Tech SaaS Platform</h3>
					<p class="text-body text-body mt-2">Full-stack React/TypeScript/Supabase platform with AI document processing, built end-to-end from zero.</p>
					<a href="/case-studies" class="text-accent text-btn mt-4 inline-block hover:text-accent-hover transition-colors duration-150 cursor-pointer">
						Read more &rarr;
					</a>
				</article>
			</div>
		</div>
	</section>

	<!-- CTA Block -->
	<section class="bg-dark py-16 sm:py-20 lg:py-24">
		<div class="max-w-6xl mx-auto px-5 sm:px-8 text-center">
			<h2 class="font-display text-white text-h2 lg:text-[3rem] lg:leading-[1.1]">Let's talk about what's slowing you down.</h2>
			<p class="text-body-lg text-body-light mt-4 max-w-xl mx-auto">30-minute call. No pitch, no pressure. Just a conversation about where you are and what might help.</p>
			<div class="mt-10 flex flex-wrap justify-center gap-4 items-center">
				<a href="https://calendly.com/chris-ssgrowthadvisors/" target="_blank" rel="noopener noreferrer" class="bg-accent text-white text-btn px-7 py-3.5 rounded hover:bg-accent-hover transition-colors duration-150 cursor-pointer inline-block">
					Book a Call
				</a>
				<a href="/contact" class="text-body-light text-btn hover:text-white transition-colors duration-150 cursor-pointer inline-block py-3.5">
					Or send a message &rarr;
				</a>
			</div>
		</div>
	</section>
</BaseLayout>
